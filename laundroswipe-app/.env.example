# Copy to .env for local `expo start`. For EAS cloud builds, set the same EXPO_PUBLIC_* keys
# in Expo → Project → Environment variables (or repo Actions secrets if you use CI).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Production API (Next.js on Vercel). No trailing slash.
EXPO_PUBLIC_API_BASE_URL=https://api.laundroswipe.com

# Supabase Dashboard → Authentication → URL configuration → Redirect URLs:
#   laundroswipeapp://auth
