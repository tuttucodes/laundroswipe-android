# Copy to .env.local and fill in real values. Never commit .env.local or any file with real secrets.
# Site URL for SEO, Open Graph (WhatsApp/social share), and canonical (e.g. https://laundroswipe.com).
NEXT_PUBLIC_APP_URL=https://laundroswipe.com

# Supabase: from project Settings > API (anon key for client; service role for server admin APIs).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Required for /api/admin/login and other admin routes (calls admin_login RPC, etc.).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Signs admin session cookies/tokens. Use a long random string; keep the same value across deploys.
# Optional fallback for signing only: ADMIN_PASSWORD (do not use real user passwords).
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Super admin and vendor passwords live in Postgres (admin_accounts), not here.
# First super admin: run supabase/scripts/bootstrap_admin.example.sql in the Supabase SQL Editor.

# Push notifications use Supabase + Expo (see deployment.md). No env vars needed in Next.js for push.
# EXPO_ACCESS_TOKEN is set in Supabase secrets for the push Edge Function.

# -----------------------------------------------------------------------------
# Abuse protection (Cloudflare Turnstile)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ENFORCE=false

# Order token length (user-visible short token). Allowed range: 4..8. Default: 4.
NEXT_PUBLIC_ORDER_TOKEN_LENGTH=4
