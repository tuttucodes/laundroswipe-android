# Supabase (same project as web app)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Web origin — mobile calls server-authoritative endpoints here
# (POST /api/orders/create, /api/vendor/*, /api/admin/*, GET /api/me/*)
EXPO_PUBLIC_WEB_ORIGIN=https://laundroswipe.com

# Google OAuth client IDs (from Google Cloud Console → OAuth 2.0)
# iOS: com.googleusercontent.apps.<client-id-prefix> — reversed scheme goes in plist
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# Optional: PostHog analytics
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# EAS project id (set by `eas init`; also injected automatically during EAS builds)
# EAS_PROJECT_ID=
