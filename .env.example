# Copy to .env.local and fill in real values. Never commit .env.local or any file with real secrets.
# Supabase: from project Settings > API (use anon public key only).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin dashboard (/admin): server-only, not exposed to client.
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=choose-a-secure-password
