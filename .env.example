# Copy to .env.local and fill in real values. Never commit .env.local or any file with real secrets.
# Site URL for SEO, Open Graph (WhatsApp/social share), and canonical (e.g. https://laundroswipe.com).
NEXT_PUBLIC_APP_URL=https://laundroswipe.com

# Supabase: from project Settings > API (anon key for client; service role for admin schedule API only).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: required for admin schedule and vendor profile writes (RLS allows only service_role to update).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin dashboard session signing secret (required).
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional emergency super-admin fallback (DB auth is preferred).
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=choose-a-secure-password

# Push notifications use Supabase + Expo (see deployment.md). No env vars needed in Next.js for push.
# EXPO_ACCESS_TOKEN is set in Supabase secrets for the push Edge Function.

# -----------------------------------------------------------------------------
# Abuse protection (Cloudflare Turnstile)
# -----------------------------------------------------------------------------
# Site key for the frontend widget. Used only for contact + "Other area request"
# captcha submissions.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Secret key used by the server to verify captcha tokens.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# When true, server will require a valid Turnstile token for public POST endpoints
# (contact, location-requests, waitlist).
# Set to "false" (or leave empty) to run rate-limit-only.
TURNSTILE_ENFORCE=false
